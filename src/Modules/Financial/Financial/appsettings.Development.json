{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LogOptions": {
    "Level": "information",
    "LogTemplate": "{Timestamp:HH:mm:ss} [{Level:u4}] {Message:lj}{NewLine}{Exception}",
    //"Elastic": {
    //  "Enabled": true,
    //  "ElasticServiceUrl": "http://localhost:9209"
    //},
    "FileOption": {
      "Enabled": true,
      "Path": "logs/logs.txt",
      "Interval": "day"
    },
    "SeqOption": {
      "Enable": true,
      "Url": "http://localhost:5349/"
    }
    //"Sentry": {
    //  "Enabled": false,
    //  "Dsn": "",
    //  "MinimumBreadcrumbLevel": "information",
    //  "MinimumEventLevel": "error"
    //}
  }
}
