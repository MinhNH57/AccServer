  <Code>Public Function ConvertNumberToText(ByVal inputNumber As Double, Optional ByVal suffix As Boolean = True) As String

    Dim unitNumbers As String() = {"không", "một", "hai", "ba", "bốn", "năm", "sáu", "bảy", "tám", "chín"}
    Dim placeValues As String() = {"", "nghìn,", "triệu,", "tỷ,"}
    Dim isNegative As Boolean = False

    Dim sNumber As String = inputNumber.ToString("#")

    If String.IsNullOrEmpty(sNumber) Then
        Return ""
    End If
    If String.Equals(sNumber, "0") Then
        Return "0 đồng."
    End If

    Dim number As Double = Math.Abs(inputNumber)

    Dim ones, tens, hundreds As Integer
    Dim positionDigit As Integer = sNumber.Length
    Dim result As String = " "

    If positionDigit = 0 Then
        result = unitNumbers(0) &amp; result
    Else
        Dim placeValue As Integer = 0

        While positionDigit &gt; 0
            tens = -1
            hundreds = -1
            ones = Convert.ToInt32(sNumber.Substring(positionDigit - 1, 1))
            positionDigit -= 1


            If positionDigit &gt; 0 Then
                tens = Convert.ToInt32(sNumber.Substring(positionDigit - 1, 1))
                positionDigit -= 1
                If positionDigit &gt; 0 Then
                    hundreds = Convert.ToInt32(sNumber.Substring(positionDigit - 1, 1))
                    positionDigit -= 1
                End If
            End If

            If ones &gt; 0 OrElse tens &gt; 0 OrElse hundreds &gt; 0 OrElse placeValue = 3 Then
                result = placeValues(placeValue) &amp; result
            End If

            placeValue += 1
            If placeValue &gt; 3 Then placeValue = 1

            If ones = 1 AndAlso tens &gt; 1 Then
                result = "một " &amp; result
            Else
                If ones = 5 AndAlso tens &gt; 0 Then
                    result = "lăm " &amp; result
                ElseIf ones &gt; 0 Then
                    result = unitNumbers(ones) &amp; " " &amp; result
                End If
            End If

            If tens &lt; 0 Then
                Exit While
            Else
                If tens = 0 AndAlso ones &gt; 0 Then result = "lẻ " &amp; result
                If tens = 1 Then result = "mười " &amp; result
                If tens &gt; 1 Then result = unitNumbers(tens) &amp; " mươi " &amp; result
            End If

            If hundreds &lt; 0 Then
                Exit While
            Else
                If hundreds &gt; 0 OrElse tens &gt; 0 OrElse ones &gt; 0 Then
                    result = unitNumbers(hundreds) &amp; " trăm " &amp; result
                End If
            End If

            result = " " &amp; result
        End While
    End If

    result = result.Trim()
    result = result.Substring(0, 1).ToUpper() &amp; result.Substring(1)

    If inputNumber &lt; 0 Then
        result = "Âm " &amp; result
    End If

    If result.EndsWith(",") Then
        result = result.Substring(0, result.Length - 1)
    End If

    result = result.Replace("lẻ", "linh")

    result &amp;= If(suffix, " đồng", "") &amp; "./."

    Return result
End Function
</Code>
