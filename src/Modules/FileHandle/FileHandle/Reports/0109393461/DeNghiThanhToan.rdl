  <DataSets>
    <DataSet Name="RequirePayment">
      <Query>
        <DataSourceName>WSamrtAcc</DataSourceName>
        <CommandText>dbo.PrintVouchersAll</CommandText>
        <CommandType>StoredProcedure</CommandType>
        <QueryParameters>
          <QueryParameter Name="@Parameter">
            <Value>=Parameters!Parameter.Value</Value>
          </QueryParameter>
