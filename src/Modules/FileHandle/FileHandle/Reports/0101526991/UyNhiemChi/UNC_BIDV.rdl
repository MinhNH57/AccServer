  <Code>Public Function CalcMoneyNumber(
    ByVal currency As String,
    ByVal vndAmount As Decimal,
    ByVal fcAmount As Decimal
) As String

    Select Case currency
        Case "VND"
            Return Format(vndAmount, "N0") &amp; " VND"

        Case "USD", "EUR", "CNY"
            Return Format(fcAmount, "N2") &amp; " " &amp; currency

        Case "JPY", "KRW"
            Return Format(fcAmount, "N0") &amp; " " &amp; currency

        Case Else
            Return ""
    End Select
End Function


Public Function CalcMoneyText_ByForeignCurrency(
    fcType As String,
    vndAmount As Decimal,
    fcAmount As Decimal
) As String

    Select Case UCase(fcType)

        Case "VND"
            Return Capitalize(ToWordsVN(vndAmount)) &amp; " đồng"

        Case "USD"
            Return ReadMoneyUSD(fcAmount)

        Case "EUR"
            Return ReadMoneyEUR(fcAmount)

        Case "JPY"
            Return Capitalize(ToWordsVN(fcAmount)) &amp; " yên Nhật"

        Case "KRW"
            Return Capitalize(ToWordsVN(fcAmount)) &amp; " won Hàn Quốc"

        Case "CNY"
            Return ReadMoneyCNY(fcAmount)

        Case Else
            Return ""
    End Select

End Function


Public Function ReadMoneyVND(vndAmount As Decimal) As String
    Return Capitalize(ToWordsVN(CLng(vndAmount))) &amp; " đồng"
End Function


Public Function ReadMoneyUSD(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim c As Integer = CInt(Math.Round((amount - d) * 100))

    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " đô la Mỹ"
    If c &gt; 0 Then r &amp;= ", " &amp; ToWordsVN(c) &amp; " cent"

    Return r
End Function


Public Function ReadMoneyEUR(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim c As Integer = CInt(Math.Round((amount - d) * 100))

    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " euro"
    If c &gt; 0 Then r &amp;= ", " &amp; ToWordsVN(c) &amp; " cent"

    Return r
End Function


Public Function ReadMoneyJPY(fcAmount As Decimal) As String
    Return Capitalize(ToWordsVN(CLng(fcAmount))) &amp; " yên Nhật"
End Function

Public Function ReadMoneyKRW(fcAmount As Decimal) As String
    Return Capitalize(ToWordsVN(CLng(fcAmount))) &amp; " won Hàn Quốc"
End Function

Public Function ReadMoneyCNY(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim h As Integer = CInt(Math.Round((amount - d) * 10))

    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " nhân dân tệ"
    If h &gt; 0 Then r &amp;= ", " &amp; ToWordsVN(h) &amp; " hào"

    Return r
End Function


Public Function ToWordsVN(ByVal amount As Decimal) As String
    If amount = 0 Then Return "không"

    Dim unit() As String = {"", " nghìn", " triệu", " tỷ", " nghìn tỷ", " triệu tỷ"}
    Dim result As String = ""
    Dim i As Integer = 0

    While amount &gt; 0
        Dim part As Integer = amount Mod 1000
        If part &gt; 0 Then
            result = Read3Digits(part) &amp; unit(i) &amp; " " &amp; result
        End If
        amount = Math.Floor(amount / 1000)
        i += 1
    End While

    Return result.Trim()
End Function


Private Function Read3Digits(ByVal number As Integer) As String
    Dim ones() As String = {
        "không", "một", "hai", "ba", "bốn",
        "năm", "sáu", "bảy", "tám", "chín"
    }

    Dim r As String = ""
    Dim hundred = number \ 100
    Dim ten = (number Mod 100) \ 10
    Dim one = number Mod 10

    If hundred &gt; 0 Then
        r &amp;= ones(hundred) &amp; " trăm"
        If ten = 0 And one &gt; 0 Then r &amp;= " lẻ"
    End If

    If ten &gt; 1 Then
        r &amp;= " " &amp; ones(ten) &amp; " mươi"
        If one = 1 Then r &amp;= " mốt"
        If one = 5 Then r &amp;= " lăm"
        If one &gt; 1 And one &lt;&gt; 5 Then r &amp;= " " &amp; ones(one)
    ElseIf ten = 1 Then
        r &amp;= " mười"
        If one = 5 Then r &amp;= " lăm"
        If one &gt; 0 And one &lt;&gt; 5 Then r &amp;= " " &amp; ones(one)
    ElseIf ten = 0 And one &gt; 0 And hundred = 0 Then
        r &amp;= ones(one)
    End If

    Return r.Trim()
End Function


Private Function Capitalize(s As String) As String
    If String.IsNullOrEmpty(s) Then Return s
    Return Char.ToUpper(s(0)) &amp; s.Substring(1)
End Function
</Code>
