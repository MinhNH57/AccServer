  <Code>Public Function CalcMoneyText(
    ByVal currency As String,
    ByVal totalAmount As Decimal
) As String
    ' Nếu không truyền currency hoặc rỗng → mặc định VND
    If String.IsNullOrWhiteSpace(currency) Then
        currency = "VND"
    End If
    
    currency = UCase(Trim(currency))
    
    Select Case currency
        Case "VND"
            Return ReadMoneyVND(totalAmount)
            
        Case "USD"
            Return ReadMoneyUSD(totalAmount)
            
        Case "EUR"
            Return ReadMoneyEUR(totalAmount)
            
        Case "JPY"
            Return ReadMoneyJPY(totalAmount)
            
        Case "KRW"
            Return ReadMoneyKRW(totalAmount)
            
        Case "CNY"
            Return ReadMoneyCNY(totalAmount)
            
        Case Else
            ' Trường hợp tiền tệ lạ → vẫn thử đọc như VND và thêm cảnh báo
            Return ReadMoneyVND(totalAmount) &amp; " (tiền tệ không xác định: " &amp; currency &amp; ")"
    End Select
End Function

' ──────────────────────────────────────────────────────────────
' Các hàm đọc chữ giữ nguyên nhưng được tinh chỉnh nhẹ
' ──────────────────────────────────────────────────────────────

Public Function ReadMoneyVND(amount As Decimal) As String
    Return "Số tiền bằng chữ: " &amp; Capitalize(ToWordsVN(CLng(Math.Round(amount)))) &amp; " đồng."
End Function

Public Function ReadMoneyUSD(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim c As Integer = CInt(Math.Round((amount - d) * 100))
    
    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " đô la Mỹ"
    If c &gt; 0 Then
        r &amp;= ", " &amp; ToWordsVN(c) &amp; IIf(c = 1, " cent", " cent")
    End If
    
    Return "Số tiền bằng chữ: " &amp; r &amp; "."
End Function

Public Function ReadMoneyEUR(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim c As Integer = CInt(Math.Round((amount - d) * 100))
    
    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " euro"
    If c &gt; 0 Then
        r &amp;= ", " &amp; ToWordsVN(c) &amp; IIf(c = 1, " cent", " cent")
    End If
    
    Return "Số tiền bằng chữ: " &amp; r &amp; "."
End Function

Public Function ReadMoneyJPY(amount As Decimal) As String
    Return "Số tiền bằng chữ: " &amp; Capitalize(ToWordsVN(CLng(Math.Round(amount)))) &amp; " yên Nhật."
End Function

Public Function ReadMoneyKRW(amount As Decimal) As String
    Return "Số tiền bằng chữ: " &amp; Capitalize(ToWordsVN(CLng(Math.Round(amount)))) &amp; " won Hàn Quốc."
End Function

Public Function ReadMoneyCNY(amount As Decimal) As String
    Dim d As Long = Fix(amount)
    Dim h As Integer = CInt(Math.Round((amount - d) * 10))   ' hào = 1/10 tệ
    
    Dim r As String = Capitalize(ToWordsVN(d)) &amp; " nhân dân tệ"
    If h &gt; 0 Then
        r &amp;= ", " &amp; ToWordsVN(h) &amp; " hào"
    End If
    
    Return "Số tiền bằng chữ: " &amp; r &amp; "."
End Function

' ──────────────────────────────────────────────────────────────
' Hàm ToWordsVN và Capitalize giữ nguyên (hoặc copy từ code cũ của bạn)
' ──────────────────────────────────────────────────────────────

Public Function ToWordsVN(ByVal amount As Long) As String
    If amount = 0 Then Return "không"
    
    Dim unit() As String = {"", " nghìn", " triệu", " tỷ", " nghìn tỷ", " triệu tỷ"}
    Dim result As String = ""
    Dim i As Integer = 0
    
    While amount &gt; 0
        Dim part As Integer = CInt(amount Mod 1000)
        If part &gt; 0 Then
            result = Read3Digits(part) &amp; unit(i) &amp; " " &amp; result
        End If
        amount = amount \ 1000
        i += 1
    End While
    
    Return result.Trim()
End Function

Private Function Read3Digits(ByVal number As Integer) As String
    ' Giữ nguyên code Read3Digits của bạn (đã tốt rồi)
    Dim ones() As String = {"không", "một", "hai", "ba", "bốn", "năm", "sáu", "bảy", "tám", "chín"}
    Dim r As String = ""
    
    Dim hundred = number \ 100
    Dim ten = (number Mod 100) \ 10
    Dim one = number Mod 10
    
    If hundred &gt; 0 Then
        r &amp;= ones(hundred) &amp; " trăm"
        If ten = 0 AndAlso one &gt; 0 Then r &amp;= " lẻ"
    End If
    
    If ten &gt; 1 Then
        r &amp;= " " &amp; ones(ten) &amp; " mươi"
        If one = 1 Then r &amp;= " mốt"
        If one = 5 Then r &amp;= " lăm"
        If one &gt; 1 AndAlso one &lt;&gt; 5 Then r &amp;= " " &amp; ones(one)
    ElseIf ten = 1 Then
        r &amp;= " mười"
        If one = 5 Then r &amp;= " lăm"
        If one &gt; 0 AndAlso one &lt;&gt; 5 Then r &amp;= " " &amp; ones(one)
    ElseIf ten = 0 AndAlso one &gt; 0 AndAlso hundred = 0 Then
        r &amp;= ones(one)
    End If
    
    Return r.Trim()
End Function

Private Function Capitalize(s As String) As String
    If String.IsNullOrEmpty(s) Then Return s
    Return Char.ToUpper(s.Chars(0)) &amp; s.Substring(1)
End Function

Public Function RemoveDuplicates(ByVal items As Object()) As String
    If items Is Nothing OrElse items.Length = 0 Then
        Return ""
    End If
    
    Dim seen As New System.Collections.Generic.HashSet(Of String)(System.StringComparer.OrdinalIgnoreCase)
    Dim result As New System.Collections.Generic.List(Of String)
    
    For Each item As Object In items
        If item IsNot Nothing Then
            Dim value As String = Convert.ToString(item)
            
            value = value.Replace(vbCrLf, " ")
            value = value.Replace(vbCr, " ")
            value = value.Replace(vbLf, " ")
            value = value.Replace(vbTab, " ")
           
            Do While value.IndexOf("  ") &gt;= 0
                value = value.Replace("  ", " ")
            Loop
            
            value = value.Trim()
            
            If value.Length &gt; 0 AndAlso Not seen.Contains(value) Then
                seen.Add(value)
                result.Add(value)
            End If
        End If
    Next
    
    Return String.Join(", ", result.ToArray())
End Function

</Code>
