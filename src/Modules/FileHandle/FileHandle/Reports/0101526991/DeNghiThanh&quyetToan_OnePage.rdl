                      <FontSize>4.327mm</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>#f44336</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=IIf(
    UCase(First(Fields!ForeignCurrencyType.Value,"PrintVouchersAll")) = "VND",

    Format(
        Sum(Fields!AmountOfMoney.Value,"PrintVouchersAll")
        - Sum(Fields!MoneyPayment.Value,"PaymentList"),
        "N0"
    ) &amp; " VND",

    Format(
        Sum(Fields!AmountOfMoneyUsd.Value,"PrintVouchersAll")
        - Sum(Fields!MoneyPaymentForeignCurrency.Value,"PaymentList"),
        "N2"
    ) &amp; " "
    &amp; UCase(First(Fields!ForeignCurrencyType.Value,"PrintVouchersAll"))
)</Value>
                    <Style>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>4.327mm</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>#f44336</Color>
                    </Style>
