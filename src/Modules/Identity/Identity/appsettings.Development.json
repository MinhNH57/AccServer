{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LogOptions": {
    "Level": "information",
    "LogTemplate": "{Timestamp:HH:mm:ss} [{Level:u4}] {Message:lj}{NewLine}{Exception}",
    //"Elastic": {
    //  "Enabled": true,
    //  "ElasticServiceUrl": "http://localhost:9200"
    //},
    "FileOption": {
      "Enabled": true,
      "Path": "logs/logs.txt",
      "Interval": "day"
    },
    "SeqOption": {
      "Enable": true,
      "Url": "http://localhost:5341/"
    }
  }
}